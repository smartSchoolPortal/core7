{% extends 'base.html.twig' %}

{% block title %}Course Search{% endblock %}

{% block body %}
    <h1>Course Search</h1>

    <form method="get">
        <label for="department">Department:</label>
        <input type="text" id="department" name="department" value="{{ department }}">

        <label for="order">Sort by name:</label>
        <select id="order" name="order">
            <option value="ASC" {% if order == 'ASC' %}selected{% endif %}>Ascending</option>
            <option value="DESC" {% if order == 'DESC' %}selected{% endif %}>Descending</option>
        </select>

        <button type="submit">Apply</button>
    </form>

    <hr>

    <table border="1">
        <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Department</th>
        </tr>
        </thead>
        <tbody>
        {% for course in courses %}
            <tr>
                <td>{{ course.id }}</td>
                <td>{{ course.name }}</td>
                <td>{{ course.department }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">No courses found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <br>

    <div>
        {% if page > 1 %}
            <a href="{{ path('app_course_search', {
                page: page - 1,
                department: department,
                order: order
            }) }}">Previous</a>
        {% endif %}

        <a href="{{ path('app_course_search', {
            page: page + 1,
            department: department,
            order: order
        }) }}">Next</a>
    </div>
    <a href="{{ path('app_schedules') }}">Back to main page</a>
{% endblock %}
