{% extends 'base.html.twig' %}

{% block title %}Smart School Portal{% endblock %}

{% block body %}
    <h1>Schedule Statistics</h1>

    <table border="1">
        <thead>
        <tr>
            <th>Schedule</th>
            <th>Courses</th>
            <th>Assignments</th>
        </tr>
        </thead>
        <tbody>
        {% for stat in stats %}
            <tr>
                <td>{{ stat.scheduleTitle }}</td>
                <td>{{ stat.courseCount }}</td>
                <td>{{ stat.assignmentCount }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">No statistics available.</td>
            </tr>
        {% endfor %}
        </tbody>
        <a href="{{ path('app_schedules') }}">Back to main page</a>
    </table>
{% endblock %}
