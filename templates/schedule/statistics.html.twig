{% extends 'base.html.twig' %}

{% block title %}Smart School Portal{% endblock %}

{% block body %}
    <h1>Schedule Statistics</h1>

    <table border="1">
        <thead>
        <tr>
            <th>Schedule</th>
            <th>Courses</th>
            <th>Assignments</th>
        </tr>
        </thead>
        <tbody>
        {% for stat in stats %}
            <tr>
                <td>{{ stat.scheduleTitle }}</td>
                <td>{{ stat.courseCount }}</td>
                <td>{{ stat.assignmentCount }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">No statistics available.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <hr>

    {% for schedule in schedules %}

        <h2>{{ schedule.title }}</h2>
        <p>{{ schedule.description }}</p>

        <a href="{{ path('app_schedule_course_new', {id: schedule.id}) }}">
            Add Course
        </a>

        <table border="1">
            <thead>
            <tr>
                <th>Course</th>
                <th>Department</th>
                <th>Assignments</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
            </thead>

            <tbody>

            {% for course in schedule.courses %}

                <tr>

                    <td>{{ course.name }}</td>

                    <td>{{ course.department }}</td>

                    <td>
                        <a href="{{ path('app_course_assignments', {id: course.id}) }}">
                            View Assignments
                        </a>
                    </td>

                    <td>
                        <a href="{{ path('app_course_edit', {id: course.id}) }}">
                            Edit
                        </a>
                    </td>

                    <td>

                        <form method="post"
                              action="{{ path('app_course_delete', {id: course.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this course?');">

                            <button type="submit">
                                Delete
                            </button>

                        </form>

                    </td>

                </tr>

            {% else %}

                <tr>
                    <td colspan="5">No courses found.</td>
                </tr>

            {% endfor %}

            </tbody>

        </table>

        <br>

    {% endfor %}

{% endblock %}
